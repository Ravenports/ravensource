DEF[SOVERSION]=		26.0.0
DEF[PORTVERSION]=	${SOVERSION}
DEF[RELEASE]=		v${PORTVERSION}
# ----------------------------------------------------------------------------

NAMEBASE=		lal-refactor
VERSION=		${PORTVERSION}
KEYWORDS=		devel ada
VARIANTS=		std
SDESC[std]=		Collection of Ada source code refactoring tools
HOMEPAGE=		https://github.com/AdaCore/lal-refactor
CONTACT=		John_Marino[draco@marino.st]

DOWNLOAD_GROUPS=	main
SITES[main]=		GITHUB/AdaCore:lal-refactor:${RELEASE}
DISTFILE[1]=		generated:main

SPKGS[std]=		set primary dev

OPTIONS_AVAILABLE=	none
OPTIONS_STANDARD=	none

LICENSE=		APACHE20:primary
LICENSE_FILE=		APACHE20:{{WRKSRC}}/LICENSE.txt
LICENSE_TERMS=		primary:{{WRKDIR}}/TERMS
LICENSE_SOURCE=		TERMS:{{WRKSRC}}/src/lal_refactor.ads
LICENSE_AWK=		TERMS:"^$$"
LICENSE_SCHEME=		solo

BUILD_DEPENDS=		libadalang-tools:dev:std
			vss-extra:dev:std
			libgpr2:dev:std
			libadalang:dev:std
			gnatcoll-core:dev:std
			gnatcoll-bindings:dev:std
			langkit_support:dev:std
BUILDRUN_DEPENDS=	libadalang-tools:primary:std
			vss-extra:primary:std

USES=			gmake gprbuild iconv:standalone ada:primary
MAKE_ARGS=		PROCESSORS={{MAKE_JOBS_NUMBER}}
			BUILD_MODE=prod
BUILD_TARGET=		lib bin
INSTALL_REQ_TOOLCHAIN=	yes
SOVERSION=		${SOVERSION}

pre-configure:
	# support soname libraries
	${REINPLACE_CMD} -e 's|@SOVERSION@|${SOVERSION}|' \
		${WRKSRC}/gnat/lal_refactor.gpr

do-build:
	# This is while.  If the job number is say "8", it will start the
	# makefile with 8 jobs, and each job can spawn 8 more jobs.  If we
	# set single jobs, then we'd be single threaded.  So we have to
	# create the standard do-build target to support single/8.

	@${ECHO_MSG} "==> cd ${BUILD_WRKSRC};"
	@${ECHO_MSG} "    ${MAKE_CMD} ${MAKE_FLAGS} ${MAKEFILE}"
	@${ECHO_MSG} "    ${MAKE_ARGS:C,^${DESTDIRNAME}=.*,,g} ${BUILD_TARGET}"
	@(cd ${BUILD_WRKSRC}; if ! ${SETENVI} ${MAKE_ENV} ${MAKE_CMD} ${MAKE_FLAGS} \
		${MAKEFILE} ${MAKE_ARGS:C,^${DESTDIRNAME}=.*,,g} ${BUILD_TARGET}; then \
		${ECHO_MSG} "===> Compilation failed unexpectedly."; \
		${FALSE}; \
	fi)

post-install:
	${STRIP_CMD} ${STAGEDIR}${PREFIX}/lib/lal_refactor.relocatable/liblal-refactor.so
	${STRIP_CMD} ${STAGEDIR}${PREFIX}/bin/lalrefactor
