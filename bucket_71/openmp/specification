DEF[NAMEBASE]=		openmp
DEF[LLVMBASE]=		llvm
DEF[CLANGBASE]=		clang
DEF[LLDBASE]=		lld
DEF[LLVM_VERSION]=	EXTRACT_INFO(LLVM22_VERSION)
DEF[PORTREVISION]=	0
DEF[MAJORMIN]=		${LLVM_VERSION:R}
DEF[MAJOR]=		${LLVM_VERSION:R:R}
DEF[WORKNAME]=		llvm-project-${LLVM_VERSION}.src
DEF[DSUBDIR]=		llvm22
# ----------------------------------------------------------------------------

NAMEBASE=		${NAMEBASE}
VERSION=		${LLVM_VERSION}
KEYWORDS=		devel lang
VARIANTS=		std
SDESC[std]=		LLVM Open Multi-Processing Runtime Library
HOMEPAGE=		http://llvm.org/
CONTACT=		nobody

DOWNLOAD_GROUPS=	main
SITES[main]=		https://github.com/llvm/llvm-project/releases/download/llvmorg-${LLVM_VERSION}/
DISTFILE[1]=		${WORKNAME}.tar.xz:main
DIST_SUBDIR=		${DSUBDIR}
DF_INDEX=		1

SPKGS[std]=		set primary dev

OPTIONS_AVAILABLE=	SUNOS
OPTIONS_STANDARD=	SUNOS
OPT_ON[sunos]=		SUNOS

LICENSE=		CUSTOM1:primary
LICENSE_NAME=		CUSTOM1:"Apache 2.0 License with LLVM Exceptions"
LICENSE_FILE=		CUSTOM1:{{WRKSRC}}/LICENSE.TXT
LICENSE_SCHEME=		solo

BUILD_DEPENDS=		${CLANGBASE}:set:std
			${LLVMBASE}:dev:std
			${LLVMBASE}:tools:std
			libxml2:dev:std
BUILDRUN_DEPENDS=	${LLVMBASE}:primary:std

# python required for OMPD GDB support (currently only builds on Linux?)

USES=			cpe cmake perl:build pkgconfig zlib ncurses:dev
			python c++:primary
CPE_VENDOR=		llvm
CPE_PRODUCT=		llvm
CMAKE_BUILD_TYPE=	Release
DISTNAME=		${WORKNAME}/openmp
CMAKE_ARGS=		-DLIBOMP_FORTRAN_MODULES:BOOL=ON
PLIST_SUB=		LLVM_MAJOR="${MAJOR}"
			LLVM_MAJORMIN="${MAJORMIN}"

[SUNOS].DESCRIPTION=			Chooses linker based on SunOS
[SUNOS].BUILD_DEPENDS_OFF=		${LLDBASE}:primary:std
[SUNOS].CMAKE_ARGS_OFF=			-DLLVM_USE_LINKER=lld

post-extract:
	${CP} ${WRKDIR}/cmake-${LLVM_VERSION}.src/Modules/* \
		${WRKSRC}/cmake/

post-install:
	${FIND} ${STAGEDIR}${PREFIX} -name "*.so" |\
		${XARGS} ${STRIP_CMD}
