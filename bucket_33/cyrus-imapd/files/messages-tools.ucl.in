primary: {
  type: "install"
  message: <<EOM
To setup mail spool, modify %%PREFIX%%/etc/imapd.conf as needed.

To run Cyrus IMAPd from startup:
   BSD:
       Add cyrus_imapd_enable="YES" in your /etc/rc.conf and
       start the imapd service in the typical fashion.
   SunOS:
       Use svcadm to start the "imapd" service.
EOM
}
