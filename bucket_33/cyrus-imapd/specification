# Turn HTTP option on by default when cyrus-imapd support libical 4.0
DEF[PORTVERSION]=	3.12.2
DEF[SOVERSION]=		0.0.0
DEF[CYRUS_USER]=	cyrus
DEF[CYRUS_GROUP]=	cyrus
# ----------------------------------------------------------------------------

NAMEBASE=		cyrus-imapd
VERSION=		${PORTVERSION}
REVISION=		2
KEYWORDS=		mail
VARIANTS=		std
SDESC[std]=		High-performance mail store with IMAP support
HOMEPAGE=		https://www.cyrusimap.org/
CONTACT=		nobody

DOWNLOAD_GROUPS=	main
SITES[main]=		https://github.com/cyrusimap/cyrus-imapd/releases/download/cyrus-imapd-${PORTVERSION}/
DISTFILE[1]=		cyrus-imapd-${PORTVERSION}.tar.gz:main

SPKGS[std]=		set primary tools dev man docs

OPTIONS_AVAILABLE=	SUNOS HTTP
OPTIONS_STANDARD=	SUNOS HTTP
OPT_ON[sunos]=		SUNOS

FPC_EQUIVALENT=		mail/cyrus-imapd312

LICENSE=		BSD4CLAUSE:primary
LICENSE_FILE=		BSD4CLAUSE:{{WRKSRC}}/COPYING
LICENSE_SCHEME=		solo

SOVERSION=		${SOVERSION}

BUILD_DEPENDS=		cyrus-sasl:dev:std
			icu:dev:std
			jansson:dev:std
			krb5:dev:std
			vim:xxd:std
			libical:dev:std
BUILDRUN_DEPENDS=	cyrus-sasl:primary:std
			icu:primary:std
			jansson:primary:std
			krb5:primary:std
			rsync:primary:std

EXRUN[tools]=		cyrus-imapd:primary:std

# we can't use libuuid:standard due to conflict in DragonFly
#    with <sys/statvfs> pulling in sys/uuid.h

USERS=			${CYRUS_USER}
GROUPS=			${CYRUS_GROUP}
USERGROUP_SPKG=		primary

USES=			cpe gmake libtool perl pkgconfig ssl:openssl30 shebangfix
			bison sqlite zlib pcre2
			smf:tools
SHEBANG_FILES=		imap/promdatagen
			tools/config2header
			tools/masssievec
			tools/mkimap
			perl/sieve/scripts/*.pl
			imap/cyr_cd.sh
CPE_VENDOR=		cyrus
CPE_PRODUCT=		imapd
SMF_NAME=		imapd
RC_SUBR=		imapd:primary
SUB_FILES=		messages-tools.ucl
			scripts-tools.ucl
			cyrus-imapd-man.conf
			imapd.conf
			manifest.xml
SUB_LIST=		CYRUS_USER=${CYRUS_USER}
			CYRUS_GROUP=${CYRUS_GROUP}
PLIST_SUB=		OWN={{USERS}}
			GRP={{GROUPS}}
MUST_CONFIGURE=		gnu
SINGLE_JOB=		yes
INSTALL_TARGET=		install-strip
INSTALL_REQ_TOOLCHAIN=	yes
MANDIRS=		{{PREFIX}}/cyrus/man

CONFIGURE_ARGS=		--libexecdir={{PREFIX}}/cyrus/libexec
			--sbindir={{PREFIX}}/cyrus/sbin
			--sysconfdir={{PREFIX}}/etc
			--localstatedir="{{PREFIX}}/var"
			--with-cyrus-user=${CYRUS_USER}
			--with-sasl={{LOCALBASE}}
			--with-sqlite={{LOCALBASE}}
			--with-com_err
			--with-openssl={{OPENSSLBASE}}
			--with-perl={{PERL}}
			--with-gss_impl=mit
			--enable-autocreate
			--enable-idled
			--enable-murder
			--enable-squat
			--enable-gssapi={{LOCALBASE}}
			--disable-replication
			--with-mysql=no
			--with-pgsql=no
			--with-clamav=no

# HTTP => CalDAV, CardDAV, WebDAV, RSS, JSON Mail Access
# libical:dev:std should be part of BUILD_DEPENDS_ON, but apparently these headers
# are always required, even when http is disabled.

[HTTP].DESCRIPTION=			Support several HTTP/DAV protocols
[HTTP].BUILD_DEPENDS_ON=		xapian-core:dev:std
					brotli:dev:std
					libnghttp2:dev:std
[HTTP].BUILDRUN_DEPENDS_ON=		libical:primary:std
					xapian-core:primary:std
					brotli:primary:std
					libnghttp2:primary:std
[HTTP].CONFIGURE_ENABLE_BOTH=		http jmap xapian calalarmd
[HTTP].CONFIGURE_WITH_BOTH=		brotli nghttp2
[HTTP].GNOME_COMPONENTS_ON=		libxml2
[HTTP].USES_ON=				zstd

[SUNOS].LDFLAGS_OFF=			-Wl,-z,execstack

pre-configure:
	${REINPLACE_CMD} -e "s|/etc/|${PREFIX}/etc/|" \
			  -e "s|%%CYRUS_USER%%|${CYRUS_USER}|g" \
			  -e "s|%%CYRUS_GROUP%%|${CYRUS_GROUP}|g" \
		${WRKSRC}/tools/mkimap
.for f in masssievec translatesieve
	${REINPLACE_CMD} -e "s|/etc/|${PREFIX}/etc/|g" \
			  -e "s|/usr/sieve|${PREFIX}/var/db/imap/sieve|g" \
		${WRKSRC}/tools/${f}
.endfor
	${REINPLACE_CMD} \
		-e 's|$$(mandir)/\(man[1358]\)|${PREFIX}/cyrus/man/\1|g' \
		${WRKSRC}/Makefile.in

post-install:
	${STRIP_CMD} ${STAGEDIR}${PREFIX}/${SITE_ARCH_REL}/auto/Cyrus/IMAP/IMAP.so
	${STRIP_CMD} ${STAGEDIR}${PREFIX}/${SITE_ARCH_REL}/auto/Cyrus/SIEVE/managesieve/managesieve.so
	${MKDIR} ${STAGEDIR}${PREFIX}/etc/man.d
	${MKDIR} ${STAGEDIR}${PREFIX}/var/db/imap/sieve
	${MKDIR} ${STAGEDIR}${PREFIX}/var/lib/imap
	${MKDIR} ${STAGEDIR}${PREFIX}/var/run/imap/socket
	${MKDIR} ${STAGEDIR}${PREFIX}/var/spool/imap
	${MKDIR} ${STAGEDIR}${PREFIX}/cyrus
	${INSTALL_DATA} ${WRKDIR}/imapd.conf \
		${STAGEDIR}${PREFIX}/etc/imapd.conf.sample
	${SED} -e 's,/run/cyrus/socket,${PREFIX}/var/run/imap/socket,' \
		${WRKSRC}/doc/examples/cyrus_conf/normal.conf \
		> ${STAGEDIR}${PREFIX}/etc/cyrus.conf.sample
	${INSTALL_SCRIPT} ${WRKSRC}/tools/mkimap \
		${STAGEDIR}${PREFIX}/cyrus/sbin/mkimap
	${INSTALL_SCRIPT} ${WRKSRC}/tools/masssievec \
		${STAGEDIR}${PREFIX}/cyrus/sbin/masssievec
	${INSTALL_DATA} ${WRKDIR}/cyrus-imapd-man.conf \
		${STAGEDIR}${PREFIX}/etc/man.d/cyrus-imapd.conf
	# documentation
	${MKDIR} ${STAGEDIR}${STD_DOCDIR}
	cd ${WRKSRC}/doc && ${COPYTREE_SHARE} . ${STAGEDIR}${STD_DOCDIR} \
		"! \( -path */html/_sources* -o -name .buildinfo \)"
	${RM} -r ${STAGEDIR}${DOCSDIR}/rst ${STAGEDIR}${STD_DOCDIR}/source
