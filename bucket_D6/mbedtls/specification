DOWNLOAD_GROUPS=	main
SITES[main]=		https://github.com/Mbed-TLS/mbedtls/releases/download/mbedtls-${PORTVERSION}/
DISTFILE[1]=		mbedtls-${PORTVERSION}.tar.bz2:main

SPKGS[std]=		set primary tools dev
SPKGS[threaded]=	set primary tools dev

OPTIONS_AVAILABLE=	THREAD
OPTIONS_STANDARD=	THREAD
VOPTS[threaded]=	THREAD=ON

FPC_EQUIVALENT=		security/mbedtls3

LICENSE=		APACHE20:primary GPLv2+:primary
LICENSE_FILE=		APACHE20:stock
			GPLv2+:stock
LICENSE_TERMS=		primary:{{WRKDIR}}/TERMS
LICENSE_AWK=		TERMS:"^The full text of each"
LICENSE_SOURCE=		TERMS:{{WRKSRC}}/LICENSE
LICENSE_SCHEME=		dual

BUILD_DEPENDS=		python-Jinja2:single:python_used

EXRUN[tools]=		primary

USES=			cpe cmake perl:build python:build
CPE_VENDOR=		arm
CPE_PRODUCT=		mbed_tls
CMAKE_ARGS=		-DENABLE_TESTING:BOOL=OFF
			-DUSE_SHARED_MBEDTLS_LIBRARY:BOOL=ON
PLIST_SUB=		SO_TLS=${SO_TLS}
			SO_509=${SO_509}
			SO_CRYPTO=${SO_CRYPTO}
			SO_TFPSA=${SO_TFPSA}
			SO_TFPSAMAJ=${SO_TFPSAMAJ}
SOVERSION=		${SOVERSION}

VAR_OPSYS[sunos]=	LDFLAGS=-lsocket

[THREAD].DESCRIPTION=			Enable multithreading
[THREAD].CMAKE_ARGS_ON=			-DLINK_WITH_PTHREAD:BOOL=ON

post-install:
	# correct obvious bug in CMakeList.txt wrt DESTDIR
	${MV} ${PREFIX}/lib/libmbedcrypto.so ${STAGEDIR}${PREFIX}/lib/
	${MV} ${PREFIX}/lib/libmbedcrypto.so.${SO_CRYPTO} ${STAGEDIR}${PREFIX}/lib/

	${STRIP_CMD} ${STAGEDIR}${PREFIX}/lib/lib*.so
	${FIND} ${STAGEDIR}${PREFIX}/bin -type f | while read f; \
	do \
	  check=$$(file "$$f" | grep "dynamically linked"); \
	  if [ -n "$$check" ]; then \
	    ${STRIP_CMD} "$$f"; \
	  fi; \
	done

pre-configure-THREAD-ON:
	${PYTHON_CMD} ${WRKSRC}/scripts/config.py set MBEDTLS_THREADING_C
	${PYTHON_CMD} ${WRKSRC}/scripts/config.py set MBEDTLS_THREADING_PTHREAD
