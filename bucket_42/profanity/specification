DEF[PORTVERSION]=	0.18.0
# ----------------------------------------------------------------------------

NAMEBASE=		profanity
VERSION=		${PORTVERSION}
KEYWORDS=		net net_im
VARIANTS=		std
SDESC[std]=		Console based XMPP client
HOMEPAGE=		https://profanity-im.github.io/
CONTACT=		nobody

DOWNLOAD_GROUPS=	main
SITES[main]=		https://profanity-im.github.io/tarballs/
DISTFILE[1]=		profanity-${PORTVERSION}.tar.xz:main

SPKGS[std]=		set primary tools dev man docs

OPTIONS_AVAILABLE=	none
OPTIONS_STANDARD=	none

LICENSE=		GPLv3+:primary
LICENSE_FILE=		GPLv3+:{{WRKSRC}}/COPYING
LICENSE_TERMS=		primary:{{WRKSRC}}/LICENSE.txt
LICENSE_SCHEME=		solo

FPC_EQUIVALENT=		net-im/profanity

BUILD_DEPENDS=		autoconf-archive:primary:std
			libnotify:dev:std
			gpgme:dev:std
			libgcrypt:dev:std
			libuuid:dev:std
			libstrophe:dev:std
			libotr:dev:std
BUILDRUN_DEPENDS=	gpgme:primary:std
			libnotify:primary:std
			libotr:primary:std
			libuuid:primary:std
			libstrophe:primary:std

EXRUN[primary]=		tools

USES=			meson ncurses pkgconfig readline ssl
			curl python sqlite expat
GNOME_COMPONENTS=	glib
MESON_ARGS=		-Dnotifications=enabled
			-Dc-plugins=enabled
			-Dotr=enabled
			-Dpgp=enabled
CFLAGS=			-I{{NCURSESINC}}

# VAR_OPSYS[linux]=	CFLAGS=-D_XOPEN_SOURCE=700
