DEF[PORTVERSION]=	EXTRACT_INFO(KDE6_FRAMEWORKS_VERSION)
DEF[KF6_COMPONENT]=	prison
# ----------------------------------------------------------------------------

NAMEBASE=		kf6-${KF6_COMPONENT}
VERSION=		${PORTVERSION}
KEYWORDS=		graphics
VARIANTS=		std
SDESC[std]=		KF6 barcode abstraction layer
HOMEPAGE=		https://api.kde.org/${KF6_COMPONENT}-index.html
CONTACT=		Michael_Reim[kraileth@elderlinux.org]

DOWNLOAD_GROUPS=	main
SITES[main]=		https://download.kde.org/stable/frameworks/${PORTVERSION:R}/
DISTFILE[1]=		${KF6_COMPONENT}-${PORTVERSION}.tar.xz:main
DIST_SUBDIR=		kde6

SPKGS[std]=		set primary dev

OPTIONS_AVAILABLE=	none
OPTIONS_STANDARD=	none

LICENSE=		MIT:primary
LICENSE_FILE=		MIT:{{WRKSRC}}/LICENSES/MIT.txt
LICENSE_TERMS=		primary:{{WRKDIR}}/TERMS
LICENSE_SOURCE=		TERMS:{{WRKSRC}}/src/lib/prison.h
LICENSE_AWK=		TERMS:"^\*"
LICENSE_SCHEME=		solo

FPC_EQUIVALENT=		graphics/kf6-${KF6_COMPONENT}

BUILD_DEPENDS=		kf6-extra-cmake-modules:primary:std
			qt6-qtbase:dev:std
			qt6-qtdeclarative:dev:std
			qt6-qtmultimedia:dev:std
			qt6-qttools:set:std
			libdmtx:dev:std
			qrencode:dev:std
			zxing-cpp:dev:std
BUILDRUN_DEPENDS=	qt6-qtbase:primary:std
			qt6-qtdeclarative:primary:std
			qt6-qtmultimedia:primary:std
			libdmtx:primary:std
			qrencode:primary:std
			zxing-cpp:primary:std

USES=			cmake
DISTNAME=		${KF6_COMPONENT}-${PORTVERSION}
CMAKE_ARGS=		-DCMAKE_PREFIX_PATH:PATH={{PREFIX}}/lib/qt6/cmake
SOVERSION=		${PORTVERSION}

post-install:
	${STRIP_CMD} ${STAGEDIR}${PREFIX}/lib/lib*.so
	${STRIP_CMD} ${STAGEDIR}${PREFIX}/lib/qt6/qml/org/kde/prison/libprisonquickplugin.so
	${STRIP_CMD} ${STAGEDIR}${PREFIX}/lib/qt6/qml/org/kde/prison/scanner/libprisonscannerquickplugin.so
