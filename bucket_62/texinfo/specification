DEF[PORTVERSION]=	7.3
DEF[DLFOLDER]=		7.3
DEF[DATE_HTMLXREF]=	20260302
DEF[DATE_TEXI2DVI]=	20260302
DEF[DATE_TEXI2PDF]=	20260302
DEF[DATE_TEXINFO_TEX]=	20260110
DEF[SOVERSION]=		1.0.0
# ----------------------------------------------------------------------------

NAMEBASE=		texinfo
VERSION=		${PORTVERSION}
KEYWORDS=		print
VARIANTS=		std
SDESC[std]=		Typeset documentation system, multiple formats
HOMEPAGE=		http://www.gnu.org/software/texinfo/
CONTACT=		nobody

DOWNLOAD_GROUPS=	main dports
SITES[main]=		GNU/texinfo
SITES[dports]=		https://leaf.dragonflybsd.org/~marino/dports-src/texinfo/${DLFOLDER}/
DISTFILE[1]=		texinfo-${PORTVERSION}.tar.xz:main
DISTFILE[2]=		texinfo.tex-${DATE_TEXINFO_TEX}:dports
DISTFILE[3]=		texi2dvi-${DATE_TEXI2DVI}:dports
DISTFILE[4]=		texi2pdf-${DATE_TEXI2PDF}:dports
DISTFILE[5]=		Texinfo_GNU.cnf-${DATE_HTMLXREF}:dports
DISTFILE[6]=		Texinfo_nonGNU.cnf-${DATE_HTMLXREF}:dports
DIST_SUBDIR=		texinfo/${DLFOLDER}
DF_INDEX=		1 2 3 4 5 6

SPKGS[std]=		set primary dev nls man info

OPTIONS_AVAILABLE=	none
OPTIONS_STANDARD=	none

LICENSE=		GPLv3+:primary
LICENSE_FILE=		GPLv3+:{{WRKSRC}}/COPYING
LICENSE_TERMS=		primary:{{WRKDIR}}/TERMS
LICENSE_AWK=		TERMS:"INFO_H"
LICENSE_SOURCE=		TERMS:{{WRKSRC}}/info/info.h
LICENSE_SCHEME=		solo

FPC_EQUIVALENT=		print/texinfo

BUILD_DEPENDS=		help2man:primary:std
EXTRACT_ONLY=		1

USES=			charsetfix cpe gmake ncurses perl
			libtool iconv:build gettext
DISTNAME=		texinfo-${PORTVERSION}
MUST_CONFIGURE=		gnu
CONFIGURE_ARGS=		--enable-nls
INSTALL_TARGET=		install install-tex
CPE_VENDOR=		gnu
CPE_VERSION=		${PORTVERSION:R}
PLIST_SUB=		TEXMF=share/texmf
INFO=			info:texinfo
			info:info-stnd
			info:texi2any_api
			info:texi2any_internals
MAKE_ARGS=		TEXMF={{LOCALBASE}}/share/texmf
			PERL={{LOCALBASE}}/bin/perl
SOVERSION=		${SOVERSION}
INSTALL_REQ_TOOLCHAIN=	yes

post-extract:
	${CHMOD} 755 ${WRKSRC}/build-aux/install-sh
	${INSTALL_DATA} ${DISTDIR}/${DIST_SUBDIR}/texinfo.tex-${DATE_TEXINFO_TEX} \
		${WRKSRC}/doc/texinfo.txt
	${INSTALL_SCRIPT} ${DISTDIR}/${DIST_SUBDIR}/texi2dvi-${DATE_TEXI2DVI} \
		${WRKSRC}/util/texi2dvi
	${INSTALL_SCRIPT} ${DISTDIR}/${DIST_SUBDIR}/texi2pdf-${DATE_TEXI2PDF} \
		${WRKSRC}/util/texi2pdf
	${INSTALL_SCRIPT} ${DISTDIR}/${DIST_SUBDIR}/Texinfo_GNU.cnf-${DATE_HTMLXREF} \
		${WRKSRC}/util/htmlxref.d/Texinfo_GNU.cnf
	${INSTALL_SCRIPT} ${DISTDIR}/${DIST_SUBDIR}/Texinfo_nonGNU.cnf-${DATE_HTMLXREF} \
		${WRKSRC}/util/htmlxref.d/Texinfo_nonGNU.cnf

post-install:
	${STRIP_CMD} ${STAGEDIR}${PREFIX}/lib/texi2any/XS_extension/*.so
	${STRIP_CMD} ${STAGEDIR}${PREFIX}/lib/texi2any/lib/*.so
