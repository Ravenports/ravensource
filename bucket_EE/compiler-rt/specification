DEF[NAMEBASE]=		compiler-rt
DEF[LLVMBASE]=		llvm
DEF[LLDBASE]=		lld
DEF[LLVM_VERSION]=	EXTRACT_INFO(LLVM22_VERSION)
DEF[WORKNAME]=		llvm-project-${LLVM_VERSION}.src
DEF[DSUBDIR]=		llvm22
# ----------------------------------------------------------------------------

NAMEBASE=		${NAMEBASE}
VERSION=		${LLVM_VERSION}
KEYWORDS=		lang devel
VARIANTS=		std
SDESC[std]=		Compiler runtime libraries for clang
HOMEPAGE=		https://compiler-rt.llvm.org/
CONTACT=		nobody

DOWNLOAD_GROUPS=	main
SITES[main]=		https://github.com/llvm/llvm-project/releases/download/llvmorg-${LLVM_VERSION}/
DISTFILE[1]=		${WORKNAME}.tar.xz:main
DIST_SUBDIR=		${DSUBDIR}
DF_INDEX=		1

SPKGS[std]=		single

OPTIONS_AVAILABLE=	SUNOS
OPTIONS_STANDARD=	SUNOS
OPT_ON[sunos]=		SUNOS

LICENSE=		CUSTOM1:single
LICENSE_NAME=		CUSTOM1:"University of Illinois/NCSA Open Source License"
LICENSE_FILE=		CUSTOM1:{{WRKSRC}}/LICENSE.TXT
LICENSE_SCHEME=		solo

# BROKEN[netbsd]=		missing headers from system root

BUILD_DEPENDS=		${LLVMBASE}:dev:std
			${LLVMBASE}:tools:std
			libxml2:dev:std
BUILDRUN_DEPENDS=	${LLVMBASE}:primary:std

B_DEPS[netbsd]=		libmd:dev:std
BR_DEPS[netbsd]=	libmd:primary:std
B_DEPS[freebsd]=	libmd:dev:std
BR_DEPS[freebsd]=	libmd:primary:std

C_USES[netbsd]=		lua:5.4,build

USES=			cpe cmake ninja zlib:build ncurses:build
			python:build c++:single
CPE_VENDOR=		llvm
CPE_PRODUCT=		llvm
DISTNAME=		${WORKNAME}/compiler-rt
PLIST_SUB=		OPSYSLC={{OPSYS:tl}}

VAR_OPSYS[netbsd]=	CXXFLAGS=-I{{LUA_INCDIR}}

[SUNOS].BUILD_DEPENDS_OFF=		${LLDBASE}:primary:std
[SUNOS].CMAKE_ARGS_OFF=			-DLLVM_USE_LINKER=lld

post-install:
	${FIND} ${STAGEDIR}${PREFIX}/lib/ -name "libclang_*.so" -exec ${STRIP_CMD} {} \;
