#!/bin/sh
#
# Init script for mariadbd.
#

. /lib/svc/share/smf_include.sh

PIDFILE="%%MARIADB_RUNDIR%%/maria.pid"

case "$1" in
start)
	if [ ! -d %%MARIADB_DBDIR%%/mysql ]; then
		%%PREFIX%%/bin/mariadb-install-db \
			--datadir=%%MARIADB_DBDIR%% \
			--user=%%MARIADB_USER%%
	fi

	%%PREFIX%%/libexec/mariadbd --user=%%MARIADB_USER%% \
		--basedir=%%PREFIX%% \
		--datadir=%%MARIADB_DBDIR%% \
		--pid-file=${PIDFILE} \
		--log-error=%%MARIADB_LOGDIR%%/error.log &
	;;
stop)
	[ -f ${PIDFILE} ] && kill `/usr/bin/head -1 ${PIDFILE}`
	;;
*)
	echo "Usage: $0 {start|stop}" >&2
	exit 1
	;;
esac

exit $SMF_EXIT_OK
