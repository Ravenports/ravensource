DEF[PORTVERSION]=	1.0.14
DEF[SOVERSION]=		1.0.0
DEF[DVERSION]=		${PORTVERSION}-2
DEF[RELEASE]=		debian-${DVERSION}
# ----------------------------------------------------------------------------

NAMEBASE=		libEMF
VERSION=		${PORTVERSION}
KEYWORDS=		graphics
VARIANTS=		std
SDESC[std]=		Enhanced Metafile generation Library
HOMEPAGE=		https://libemf.sourceforge.net/
CONTACT=		Michael_Reim[kraileth@elderlinux.org]

DOWNLOAD_GROUPS=	main
# SITES[main]=		SF/libemf/libemf/${PORTVERSION}
SITES[main]=		https://salsa.debian.org/debian/libemf/-/archive/debian/${DVERSION}/
DISTFILE[1]=		libemf-${RELEASE}.tar.gz:main

SPKGS[std]=		set primary dev tools

OPTIONS_AVAILABLE=	none
OPTIONS_STANDARD=	none

LICENSE=		LGPL21+:primary
LICENSE_FILE=		LGPL21+:{{WRKSRC}}/COPYING.LIB
LICENSE_TERMS=		primary:{{WRKDIR}}/TERMS
LICENSE_SOURCE=		TERMS:{{WRKSRC}}/libemf/libemf.h
LICENSE_AWK=		TERMS:"_LIBEMF_H"
LICENSE_SCHEME=		solo

FPC_EQUIVALENT=		graphics/libemf

EXRUN[tools]=		primary

C_USES[netbsd]=		iconv

USES=			cpe cmake c++:primary
CPE_VENDOR=		libemf_project
CPE_PRODUCT=		libemf
DISTNAME=		libemf-${RELEASE}
CMAKE_ARGS=		-DENABLE_EDITING:BOOL=ON
			-DBUILD_SHARED_LIBS:BOOL=ON
SOVERSION=		${SOVERSION}

VAR_OPSYS[netbsd]=	LDFLAGS={{ICONV_LIB}}

post-install:
	${STRIP_CMD} ${STAGEDIR}${PREFIX}/lib/libemf.so
	${STRIP_CMD} ${STAGEDIR}${PREFIX}/bin/printemf
