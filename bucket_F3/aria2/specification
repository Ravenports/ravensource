DEF[PORTVERSION]=	1.37.0
# ----------------------------------------------------------------------------

NAMEBASE=		aria2
VERSION=		${PORTVERSION}
REVISION=		2
KEYWORDS=		ftp net www
VARIANTS=		std
SDESC[std]=		CLI download for HTTP/S, FTP, BitTorrent, Metalink
HOMEPAGE=		https://aria2.github.io/
CONTACT=		nobody

DOWNLOAD_GROUPS=	main
SITES[main]=		https://github.com/aria2/aria2/releases/download/release-${PORTVERSION}/
DISTFILE[1]=		aria2-${PORTVERSION}.tar.xz:main

SPKGS[std]=		set primary tools dev man docs

OPTIONS_AVAILABLE=	none
OPTIONS_STANDARD=	none

LICENSE=		GPLv2+:primary
LICENSE_FILE=		GPLv2+:{{WRKSRC}}/COPYING
LICENSE_TERMS=		primary:{{WRKDIR}}/TERMS
LICENSE_AWK=		TERMS:"copyright -->"
LICENSE_SOURCE=		TERMS:{{WRKSRC}}/src/main.cc
LICENSE_SCHEME=		solo

FPC_EQUIVALENT=		www/aria2

EXRUN[tools]=		primary

USERS=			aria2
GROUPS=			aria2
USERGROUP_SPKG=		tools

RC_SUBR=		aria2:tools

USES=			cpe libtool pkgconfig ssl sqlite zlib mbsdfix c++:primary
			rootca:tools
			smf:tools
GNOME_COMPONENTS=	libxml2
CPE_VENDOR=		aria2_project
INSTALL_TARGET=		install-strip
MUST_CONFIGURE=		gnu
CONFIGURE_ARGS=		--disable-epoll
			--disable-nls
			--enable-bittorrent
			--enable-libaria2
			--enable-metalink
			--enable-shared
			--enable-ssl
			--enable-static
			--enable-threads=posix
			--enable-websocket
			--with-disk-cache=16M
			--with-libxml2
			--with-libz
			--with-openssl
			--with-sqlite3
			--with-ca-bundle={{LOCALBASE}}/share/certs/ca-root-nss.crt
			--without-appletls
			--without-gnutls
			--without-libexpat
			--without-libgcrypt
			--without-libgmp
			--without-libnettle
			--without-libuv
			--without-libcares
			--without-libintl-prefix
			--without-libssh2
CONFIGURE_ENV=		OPENSSL_CFLAGS=-I{{OPENSSLINC}}
			OPENSSL_LIBS="-L{{OPENSSLLIB}} -lcrypto -lssl"
			ac_cv_path_RST2HTML=no
SUB_FILES=		manifest.xml
			aria2.conf.sample
SUB_LIST=		ARIA2_USR={{USERS}}
			ARIA2_GRP={{GROUPS}}
PLIST_SUB=		OWN={{USERS}}
			GRP={{GROUPS}}

post-patch:
	${REINPLACE_CMD} -e '/GAI_STRERROR/d' ${WRKSRC}/src/Makefile.in

post-install:
	${MKDIR} ${STAGEDIR}${PREFIX}/etc/bash_completion.d/
	${MKDIR} ${STAGEDIR}${PREFIX}/var/log/aria2
	${MKDIR} ${STAGEDIR}${PREFIX}/var/db/aria2
	${INSTALL_DATA} ${WRKSRC}/doc/bash_completion/aria2c \
		${STAGEDIR}${PREFIX}/etc/bash_completion.d/
	${INSTALL_DATA} ${WRKDIR}/aria2.conf.sample ${STAGEDIR}${PREFIX}/etc/
