# Basic Settings
dir=%%PREFIX%%/var/db/aria2
continue=true
max-concurrent-downloads=5
max-connection-per-server=16
min-split-size=20M
split=10
disable-ipv6=false

# Advanced Settings
file-allocation=falloc
log-level=warn
log=%%PREFIX%%/var/log/aria2/aria2.log

# BitTorrent Settings
bt-max-peers=55
enable-dht=true
enable-peer-exchange=true
seed-ratio=1.0
seed-time=0

# RPC Settings (for Web UIs like AriaNg)
enable-rpc=true
rpc-allow-origin-all=true
rpc-listen-all=true
rpc-listen-port=6800
# It is highly recommended to set a secret token
# rpc-secret=YourSecureTokenHere
