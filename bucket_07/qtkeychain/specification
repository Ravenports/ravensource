DEF[PORTVERSION]=	0.15.0
DEF[TAG]=		${PORTVERSION}
DEF[QT_MKSPECDIR_REL]=	lib/qt6/mkspecs
DEF[SOVERSION]=		${PORTVERSION}
# ----------------------------------------------------------------------------

NAMEBASE=		qtkeychain
VERSION=		${PORTVERSION}
KEYWORDS=		security
VARIANTS=		std
SDESC[std]=		Qt API for storing passwords securely
HOMEPAGE=		https://github.com/frankosterfeld/qtkeychain
CONTACT=		nobody

DOWNLOAD_GROUPS=	main
SITES[main]=		GITHUB/frankosterfeld:qtkeychain:${TAG}
DISTFILE[1]=		generated:main

SPKGS[std]=		set primary dev nls

OPTIONS_AVAILABLE=	none
OPTIONS_STANDARD=	none

LICENSE=		BSD2CLAUSE:primary
LICENSE_FILE=		BSD2CLAUSE:{{WRKSRC}}/COPYING
LICENSE_SCHEME=		solo

FPC_EQUIVALENT=		security/qtkeychain

BUILD_DEPENDS=		libsecret:dev:std
			qt6-qtbase:dev:std
			qt6-qttools:set:std
BUILDRUN_DEPENDS=	libsecret:primary:std
			qt6-qtbase:primary:std

USES=			cmake pkgconfig gettext
CMAKE_ARGS=		-DBUILD_WITH_QT6:BOOL=ON
			-DBUILD_TRANSLATIONS:BOOL=ON
			-DLIBSECRET_SUPPORT:BOOL=ON
			-DCMAKE_PREFIX_PATH:PATH={{PREFIX}}/lib/qt6/cmake
SOVERSION=		${SOVERSION}

post-install:
	${STRIP_CMD} ${STAGEDIR}${PREFIX}/lib/libqt6keychain.so
